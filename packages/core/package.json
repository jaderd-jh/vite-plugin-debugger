{
  "name": "vite-plugin-debugger",
  "type": "module",
  "version": "0.5.0",
  "description": "A vite plugin provide the debugger tools for mobile devices.",
  "author": "jade-gjz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaderd-jh/vite-plugin-debugger.git"
  },
  "keywords": [
    "vite",
    "debugger",
    "plugin",
    "eruda",
    "vConsole",
    "mobile"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./eruda": "./dist/eruda.mjs",
    "./vconsole": "./dist/vconsole.mjs",
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublish": "pnpm build",
    "lint": "eslint . --fix",
    "prepublishOnly": "publint",
    "release": "bumpp",
    "publint": "npx publint"
  },
  "peerDependencies": {
    "eruda": "^3.0.0",
    "vconsole": "^3.14.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "eruda": {
      "optional": true
    },
    "vconsole": {
      "optional": true
    }
  },
  "dependencies": {
    "local-pkg": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "tsdown": "^0.22.1",
    "vite": "^8.0.14"
  }
}
